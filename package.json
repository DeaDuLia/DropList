{
  "name": "DropList",
  "version": "1.0.0",
  "main": "main.js",
  "author": "Nikita <nvdeshin@gmail.com>",
  "description": "Media catalog application",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build-win": "npm run rebuild && electron-builder --win",
    "build-mac": "npm run rebuild && electron-builder --mac --config.mac.identity=null",
    "build-linux": "npm run rebuild && electron-builder --linux"
  },
  "build": {
    "appId": "com.deshin.droplist",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "nvdeshin@gmail.com"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "publish": null,
    "extraResources": [
      {
        "from": "database.db",
        "to": "../"
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9"
  }
}